<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/send_dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:id="@+id/dashboard_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/dashboard_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dashboard_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mission Link Console"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dashboard_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Encrypted link posture, payload budget, and interoperable mission traffic."
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/theme_mode_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark Ops"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/chip_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/route_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:text="Active route" />

            <TextView
                android:id="@+id/endpoint_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:text="Endpoint" />

            <TextView
                android:id="@+id/mission_profile_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:text="Profile" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/summary_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/summary_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operational Summary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/operational_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Preparing dashboard..."
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/stat_route_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_route_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Route"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_active_route_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="BLE"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_payload_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_payload_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payload Budget"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_payload_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 / 512 B"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/stat_last_send_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_last_send_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Send"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_last_send_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Never"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_delivery_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_delivery_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Ratio"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_delivery_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/payload_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Compose a message to see how it fits inside the radio envelope."
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/payload_budget_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="10dp"
                android:max="512"
                android:progress="0" />

            <TextView
                android:id="@+id/last_operation_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No transmissions recorded yet."
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/assurance_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/assurance_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mission Assurance"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/assurance_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Assessing encryption, audit, and interoperability posture."
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/assurance_encryption_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/assurance_encryption_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encryption"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/assurance_encryption_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting status"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/assurance_audit_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/assurance_audit_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audit"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/assurance_audit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting status"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/assurance_interop_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/assurance_interop_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interoperability"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/assurance_interop_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting status"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/assurance_provisioning_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/assurance_provisioning_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Provisioning"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/assurance_provisioning_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting status"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mailbox_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/mailbox_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guaranteed Delivery Mailbox"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/mailbox_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Queued mission traffic will hold until a bearer becomes available."
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/mailbox_pending_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/mailbox_pending_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/mailbox_pending_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/mailbox_in_flight_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/mailbox_in_flight_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="In Flight"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/mailbox_in_flight_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/mailbox_delivered_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/mailbox_delivered_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivered"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/mailbox_delivered_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/mailbox_failover_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/mailbox_failover_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Failover"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/mailbox_failover_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Auto failover armed"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/mailbox_replay_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/mailbox_replay_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Replay"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/mailbox_replay_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 checkpoints"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/retry_mailbox_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Retry Queue"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/replay_mission_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="Replay Last Mission"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

                <LinearLayout
                    android:id="@+id/incident_board_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/incident_board_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Incident Board"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/incident_board_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Loading incident board..."
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/incident_title_card"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/incident_title_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Incident"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/incident_title_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Search Grid"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/incident_role_pack_card"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/incident_role_pack_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Role Pack"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/incident_role_pack_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="SAR Field Team"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/incident_tempo_card"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/incident_tempo_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tempo"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/incident_tempo_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Responsive"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/incident_next_action_card"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/incident_next_action_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Next Action"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/incident_next_action_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Prepare extraction support update."
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/incident_role_action_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Queue role-pack actions into the secure composer."
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Spinner
                            android:id="@+id/incident_role_action_spinner"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:spinnerMode="dropdown" />

                        <Button
                            android:id="@+id/load_role_action_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Queue Action"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>

        <LinearLayout
            android:id="@+id/trend_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/trend_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Payload Trend"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trend_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Last 12 encrypted transmissions measured against the 512-byte field envelope."
                android:textSize="13sp" />

            <com.akitaengineering.meshtak.ui.PayloadTrendChartView
                android:id="@+id/payload_trend_chart"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/format_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/format_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Format Distribution"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/format_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Actual traffic mix across ATAK, JSON, and custom interoperability frames."
                android:textSize="13sp" />

            <com.akitaengineering.meshtak.ui.FormatDistributionChartView
                android:id="@+id/format_distribution_chart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/plain_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/plain_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Plain Text 0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/json_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/json_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="JSON 0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/custom_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/custom_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Custom 0" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/composer_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/composer_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transmit Payload"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/composer_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Prepare a secure frame and verify payload budget before release."
                android:textSize="13sp" />

            <TextView
                android:id="@+id/template_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Mission playbooks load profile-specific secure payloads for rapid execution."
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/mission_template_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:spinnerMode="dropdown" />

                <Button
                    android:id="@+id/load_template_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Load Playbook"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Spinner
                android:id="@+id/data_format_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/data_to_send"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="top|start"
                android:hint="Enter CoT XML, JSON, or command"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:padding="14dp" />

            <TextView
                android:id="@+id/payload_metrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Draft size: 0 / 512 bytes"
                android:textSize="13sp" />

            <Button
                android:id="@+id/send_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Transmit"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/history_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/history_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rapid Reuse"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/history_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Recent secure commands and interoperable frames will appear here after transmission."
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/command_history_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
