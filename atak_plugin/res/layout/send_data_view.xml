<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/send_dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:id="@+id/dashboard_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/dashboard_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dashboard_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mission Link Console"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dashboard_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Encrypted link posture, payload budget, and interoperable mission traffic."
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/theme_mode_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark Ops"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/chip_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/route_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:text="Active route" />

            <TextView
                android:id="@+id/endpoint_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingTop="8dp"
                android:paddingRight="12dp"
                android:paddingBottom="8dp"
                android:text="Endpoint" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/summary_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/summary_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operational Summary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/operational_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Preparing dashboard..."
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/stat_route_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_route_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Route"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_active_route_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="BLE"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_payload_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_payload_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payload Budget"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_payload_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 / 512 B"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/stat_last_send_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_last_send_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Send"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_last_send_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Never"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/stat_delivery_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/stat_delivery_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Ratio"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/stat_delivery_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Awaiting"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/payload_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Compose a message to see how it fits inside the radio envelope."
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/payload_budget_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="10dp"
                android:max="512"
                android:progress="0" />

            <TextView
                android:id="@+id/last_operation_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="No transmissions recorded yet."
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trend_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/trend_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Payload Trend"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trend_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Last 12 encrypted transmissions measured against the 512-byte field envelope."
                android:textSize="13sp" />

            <com.akitaengineering.meshtak.ui.PayloadTrendChartView
                android:id="@+id/payload_trend_chart"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/format_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/format_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Format Distribution"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/format_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Actual traffic mix across ATAK, JSON, and custom interoperability frames."
                android:textSize="13sp" />

            <com.akitaengineering.meshtak.ui.FormatDistributionChartView
                android:id="@+id/format_distribution_chart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/plain_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/plain_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Plain Text 0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/json_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/json_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="JSON 0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/custom_legend_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp" />

                    <TextView
                        android:id="@+id/custom_legend_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Custom 0" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/composer_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/composer_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transmit Payload"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/composer_card_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Prepare a secure frame and verify payload budget before release."
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/data_format_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:spinnerMode="dropdown" />

            <EditText
                android:id="@+id/data_to_send"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="top|start"
                android:hint="Enter CoT XML, JSON, or command"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:padding="14dp" />

            <TextView
                android:id="@+id/payload_metrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Draft size: 0 / 512 bytes"
                android:textSize="13sp" />

            <Button
                android:id="@+id/send_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Transmit"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/history_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/history_card_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rapid Reuse"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/history_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Recent secure commands and interoperable frames will appear here after transmission."
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/command_history_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
